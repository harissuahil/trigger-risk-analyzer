  <label>DML in Loop</label>
  <values>
    <field>Rule_Key__c</field>
    <value xsi:type="xsd:string">DML_IN_LOOP</value>
  </values>
  <values>
    <field>Severity__c</field>
    <value xsi:type="xsd:string">High</value>
  </values>
  <values>
    <field>Category__c</field>
    <value xsi:type="xsd:string">BulkRisk</value>
  </values>
  <values>
