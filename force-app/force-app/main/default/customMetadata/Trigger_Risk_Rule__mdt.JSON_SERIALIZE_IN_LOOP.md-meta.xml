<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <label>JSON serialize in Loop</label>
  <values>
    <field>Rule_Key__c</field>
    <value xsi:type="xsd:string">JSON_SERIALIZE_IN_LOOP</value>
  </values>
  <values>
    <field>Severity__c</field>
    <value xsi:type="xsd:string">Low</value>
  </values>
  <values>
    <field>Category__c</field>
    <value xsi:type="xsd:string">Performance</value>
  </values>
  <values>
    <field>Pattern__c</field>
    <value xsi:type="xsd:string">(?s)\b(for|while)\s*\(.*?\)\s*\{[\s\S]{0,300}?\bJSON\.(serialize|deserialize)\b</value>
  </values>
  <values>
    <field>Message__c</field>
    <value xsi:type="xsd:string">JSON serialization detected inside a loop. Consider moving outside loop if possible.</value>
  </values>
</CustomMetadata>
